{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "approvedEstablishmentCronFrequency": {
      "type": "string"
    },
    "approvedEstablishmentServiceDBPassword": {
      "type": "securestring"
    },
    "approvedEstablishmentServiceDBPasswordAD": {
      "type": "securestring"
    },
    "approvedEstablishmentServiceDBPasswordNew": {
      "type": "securestring"
    },
    "approvedEstablishmentServiceDBUsername": {
      "type": "string"
    },
    "approvedEstablishmentServiceDBUsernameAD": {
      "type": "string"
    },
    "approvedEstablishmentServiceName": {
      "type": "string"
    },
    "blueGreen": {
      "type": "string"
    },
    "containerStartTimeLimit": {
      "type": "string"
    },
    "commodityCodeCronFrequency": {
      "type": "string"
    },
    "commodityCodeServiceDBPassword": {
      "type": "securestring"
    },
    "commodityCodeServiceDBPasswordAD": {
      "type": "securestring"
    },
    "commodityCodeServiceDBPasswordNew": {
      "type": "securestring"
    },
    "commodityCodeServiceDBUsername": {
      "type": "string"
    },
    "commodityCodeServiceDBUsernameAD": {
      "type": "string"
    },
    "commodityCodeServiceName": {
      "type": "string"
    },
    "containerRepository": {
      "type": "string"
    },
    "databaseName": {
      "type": "string"
    },
    "dateCreated": {
      "type": "string"
    },
    "dbLoginTimeout": {
      "type": "string"
    },
    "dbSocketTimeout": {
      "type": "string"
    },
    "dnsCacheTtl": {
      "type": "string"
    },
    "dnsSuffix": {
      "type": "string"
    },
    "dockerRegistryPassword": {
      "type": "securestring"
    },
    "dockerRegistryServerUrl": {
      "type": "string"
    },
    "dockerRegistryServerUsername": {
      "type": "string"
    },
    "envCode": {
      "type": "string"
    },
    "envSuffix": {
      "type": "string"
    },
    "healthcheckMaxFailures": {
      "type": "int"
    },
    "hikariDebugLevel": {
      "type": "string"
    },
    "hikariLeakDetectionThreshold": {
      "type": "string"
    },
    "hikariConnectionTimeout": {
      "type": "string"
    },
    "hikariValidationTimeout": {
      "type": "string"
    },
    "javaToolOptions": {
      "type": "string"
    },
    "jwtAudience": {
      "type": "string"
    },
    "jwtPrivateKey": {
      "type": "securestring"
    },
    "permissionsServiceBasicAuthPassword": {
      "type": "securestring"
    },
    "proxyHost": {
      "type": "string"
    },
    "readOnlyDatabase": {
      "type": "bool"
    },
    "rdsApiClient": {
      "type": "string"
    },
    "rdsApiKey": {
      "type": "securestring"
    },
    "rdsApiUrl": {
      "type": "string"
    },
    "rdsDnsSuffix": {
      "type": "string"
    },
    "serviceCode": {
      "type": "string"
    },
    "serviceDBHost": {
      "type": "string"
    },
    "serviceDBPassword": {
      "type": "securestring"
    },
    "serviceDBPasswordAD": {
      "type": "securestring"
    },
    "serviceDBPasswordNew": {
      "type": "securestring"
    },
    "serviceDBUsername": {
      "type": "string"
    },
    "serviceDBUsernameAD": {
      "type": "string"
    },
    "serviceName": {
      "type": "string"
    },
    "servicePlanGroup": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "WebvNetResourceGroup": {
      "type": "string"
    },
    "WebvNetName": {
      "type": "string"
    },
    "WebSubnetName-reference-data-plan-1": {
      "type": "string"
    },
    "WebSubnetName-reference-data-plan-2": {
      "type": "string"
    },
    "WebSubnetName-low-traffic-plan-1": {
      "type": "string"
    },
    "WebSubnetName-high-traffic-plan-1": {
      "type": "string"
    },
    "WebSubnetName-frontend-plan-1": {
      "type": "string"
    },
    "WebSubnetName-soap-services-plan-1": {
      "type": "string"
    },
    "DeploymentSubnetResourceId": {
      "type": "string"
    },
    "sharedInfraResourceGroupName": {
      "type": "string"
    },
    "rtlDeploymentCheckSubnetResourceId": {
      "type": "string"
    }
  },
  "variables": {
    "appInsightsName": "[concat('insights-',if(empty(parameters('sharedInfraResourceGroupName')), resourceGroup().name, parameters('sharedInfraResourceGroupName')), if(not(empty(parameters('blueGreen'))), concat('-', parameters('blueGreen')),''))]",
    "approvedEstablishmentDatabaseName": "[if(empty(parameters('blueGreen')), concat(parameters('approvedEstablishmentServiceName'), '-', parameters('envSuffix')), concat(parameters('approvedEstablishmentServiceName'), '-', parameters('blueGreen')))]",
    "commodityDatabaseName": "[if(empty(parameters('blueGreen')), concat(parameters('commodityCodeServiceName'), '-', parameters('envSuffix')), concat(parameters('commodityCodeServiceName'), '-', parameters('blueGreen')))]",
    "databaseNameFull": "[if(empty(parameters('blueGreen')), concat(parameters('databaseName'), '-', parameters('envSuffix')), concat(parameters('databaseName'), '-', parameters('blueGreen')))]",
    "dockerCustomImageName": "[concat(parameters('dockerRegistryServerUrl'), '/', parameters('containerRepository'), '/', 'referencedataloader-microservice', ':', parameters('version'))]",
    "envDomain": "[if(empty(parameters('blueGreen')), concat('-', parameters('envSuffix'),  parameters('dnsSuffix')), concat('-', parameters('blueGreen'), parameters('dnsSuffix')))]",
    "rdsApiEnvDomain": "[if(empty(parameters('envSuffix')), parameters('rdsDnsSuffix'), if(equals(parameters('envSuffix'), 'vnet'), parameters('rdsDnsSuffix'), concat('-', parameters('envSuffix'),  parameters('rdsDnsSuffix'))))]",
    "proxyUrl": "[concat('https://', parameters('proxyHost'), parameters('dnsSuffix'))]",
    "servicePlanName": "[if(empty(parameters('blueGreen')), concat(parameters('servicePlanGroup'), '-', parameters('envSuffix')), parameters('servicePlanGroup'))]",
    "ipSecurityRestrictions": "[if(equals(parameters('envSuffix'), 'vnet'), union(variables('vnetIpSecurityRestrictions'), variables('commonIpSecurityRestrictions')), union(variables('commonIpSecurityRestrictions'), variables('rtlIpSecurityRestrictions')))]",
    "vnetIpSecurityRestrictions":
        [
          {
              "ipAddress": "195.89.171.5/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 120,
              "name": "KainosVPN1",
              "description": "Allow access from Kainos VPN1"
          },
          {
              "ipAddress": "195.89.171.144/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 121,
              "name": "KainosVPN2",
              "description": "Allow access from Kainos VPN2"
          },
          {
              "ipAddress": "62.254.63.52/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 122,
              "name": "KainosVPN3",
              "description": "Allow access from Kainos VPN3"
          },
          {
              "vnetSubnetResourceId": "[if(empty(parameters('DeploymentSubnetResourceId')), resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-soap-services-plan-1')), parameters('DeploymentSubnetResourceId'))]",
              "action": "Allow",
              "tag": "Default",
              "priority": 107,
              "name": "AllowDeploymentChecks"
          }
        ],
    "rtlIpSecurityRestrictions":
        [
            {
                "vnetSubnetResourceId": "[parameters('rtlDeploymentCheckSubnetResourceId')]",
                "action": "Allow",
                "tag": "Default",
                "priority": 109,
                "name": "AllowRtlDeploymentChecks"
            }
        ],
    "commonIpSecurityRestrictions":
        [
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-reference-data-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 101,
                "name": "AllowReferenceDataPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-reference-data-plan-2'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 102,
                "name": "AllowReferenceDataPlan2"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-low-traffic-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 103,
                "name": "AllowLowTrafficPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-high-traffic-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 104,
                "name": "AllowHighTrafficPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-frontend-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 105,
                "name": "AllowFrontendPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-soap-services-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 106,
                "name": "AllowSoapServicesPlan1"
            },
            {
                "ipAddress": "Any",
                "action": "Deny",
                "priority": 2147483647,
                "name": "Deny all",
                "description": "Deny all access"
            }
        ]
    },
  "resources": [
    {
      "name": "[parameters('serviceName')]",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2020-12-01",
      "location": "[resourceGroup().location]",
      "tags": {
        "Name": "[parameters('serviceName')]",
        "ServiceCode": "[parameters('serviceCode')]",
        "ServiceName": "[concat('EUX Imports:', parameters('serviceName'))]",
        "ServiceType": "LOB",
        "CreationDateTime": "[parameters('dateCreated')]",
        "Environment": "[parameters('envCode')]",
        "Tier": "WEB",
        "Region": "[resourceGroup().location]"
      },
      "properties": {
        "name": "[parameters('serviceName')]",
        "serverFarmId": "[concat(resourceGroup().id, '/providers/Microsoft.Web/serverfarms/', variables('servicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', variables('dockerCustomImageName'))]",
          "httpLoggingEnabled": true,
          "logsDirectorySizeLimit": 35,
          "detailedErrorLoggingEnabled": false,
          "publishingUsername": "[parameters('serviceName')]",
          "appSettings": [
            {
              "name": "WEBSITE_VNET_ROUTE_ALL",
              "value": "[if(empty(parameters('WebvNetResourceGroup')), '0', '1')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId(if(empty(parameters('sharedInfraResourceGroupName')), resourceGroup().name, parameters('sharedInfraResourceGroupName')), 'Microsoft.Insights/components', variables('appInsightsName')), '2015-05-01').ConnectionString]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_HOST",
              "value": "[parameters('serviceDBHost')]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_NAME",
              "value": "[variables('approvedEstablishmentDatabaseName')]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_PASSWORD",
              "value": "[parameters('approvedEstablishmentServiceDBPassword')]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_PASSWORD_AD",
              "value": "[parameters('approvedEstablishmentServiceDBPasswordAD')]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_PASSWORD_NEW",
              "value": "[parameters('approvedEstablishmentServiceDBPasswordNew')]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_PORT",
              "value": "1433"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_USER",
              "value": "[parameters('approvedEstablishmentServiceDBUsername')]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_USER_AD",
              "value": "[parameters('approvedEstablishmentServiceDBUsernameAD')]"
            },
            {
              "name": "COMMODITYCODE_DB_HOST",
              "value": "[parameters('serviceDBHost')]"
            },
            {
              "name": "APPROVED_ESTABLISHMENT_DB_URL",
              "value": "[concat('jdbc:sqlserver://', parameters('serviceDBHost'), ':1433;databaseName=', variables('approvedEstablishmentDatabaseName'), ';user=', parameters('approvedEstablishmentServiceDBUsernameAD'), ';password=', parameters('approvedEstablishmentServiceDBPasswordAD'), ';trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;encrypt=true;socketTimeout=', parameters('dbSocketTimeout'), ';loginTimeout=', parameters('dbLoginTimeout'), ';authentication=ActiveDirectoryPassword')]"
            },
            {
              "name": "COMMODITYCODE_DB_NAME",
              "value": "[variables('commodityDatabaseName')]"
            },
            {
              "name": "COMMODITYCODE_DB_PASSWORD",
              "value": "[parameters('commodityCodeServiceDBPassword')]"
            },
            {
              "name": "COMMODITYCODE_DB_PASSWORD_AD",
              "value": "[parameters('commodityCodeServiceDBPasswordAD')]"
            },
            {
              "name": "COMMODITYCODE_DB_PASSWORD_NEW",
              "value": "[parameters('commodityCodeServiceDBPasswordNew')]"
            },
            {
              "name": "COMMODITYCODE_DB_PORT",
              "value": "1433"
            },
            {
              "name": "COMMODITYCODE_DB_USER",
              "value": "[parameters('commodityCodeServiceDBUsername')]"
            },
            {
              "name": "COMMODITYCODE_DB_USER_AD",
              "value": "[parameters('commodityCodeServiceDBUsernameAD')]"
            },
            {
              "name": "COMMODITYCODE_DB_URL",
              "value": "[concat('jdbc:sqlserver://', parameters('serviceDBHost'), ':1433;databaseName=', variables('commodityDatabaseName'), ';user=', parameters('commodityCodeServiceDBUsernameAD'), ';password=', parameters('commodityCodeServiceDBPasswordAD'), ';trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;encrypt=true;socketTimeout=', parameters('dbSocketTimeout'), ';loginTimeout=', parameters('dbLoginTimeout'), ';authentication=ActiveDirectoryPassword')]"
            },
            {
              "name": "DATE_DEPLOYED",
              "value": "[parameters('dateCreated')]"
            },
            {
              "name": "DB_HOST",
              "value": "[parameters('serviceDBHost')]"
            },
            {
              "name": "DB_LOGIN_TIMEOUT",
              "value": "[parameters('dbLoginTimeout')]"
            },
            {
              "name": "DB_NAME",
              "value": "[variables('databaseNameFull')]"
            },
            {
              "name": "DB_PASSWORD",
              "value": "[parameters('serviceDBPassword')]"
            },
            {
              "name": "DB_PASSWORD_AD",
              "value": "[parameters('serviceDBPasswordAD')]"
            },
            {
              "name": "DB_PASSWORD_NEW",
              "value": "[parameters('serviceDBPasswordNew')]"
            },
            {
              "name": "DB_PORT",
              "value": "1433"
            },
            {
              "name": "DB_SOCKET_TIMEOUT",
              "value": "[parameters('dbSocketTimeout')]"
            },
            {
              "name": "DB_USER",
              "value": "[parameters('serviceDBUsername')]"
            },
            {
              "name": "DB_USER_AD",
              "value": "[parameters('serviceDBUsernameAD')]"
            },
            {
              "name": "DNS_CACHE_TTL",
              "value": "[parameters('dnsCacheTtl')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('dockerRegistryPassword')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[parameters('dockerRegistryServerUrl')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[parameters('dockerRegistryServerUsername')]"
            },
            {
              "name": "ENV_DOMAIN",
              "value": "[variables('envDomain')]"
            },
            {
              "name": "HIKARI_DEBUG_LEVEL",
              "value": "[parameters('hikariDebugLevel')]"
            },
            {
              "name": "HIKARI_LEAK_DETECTION_THRESHOLD",
              "value": "[parameters('hikariLeakDetectionThreshold')]"
            },
            {
              "name": "HIKARI_CONNECTION_TIMEOUT",
              "value": "[parameters('hikariConnectionTimeout')]"
            },
            {
              "name": "HIKARI_VALIDATION_TIMEOUT",
              "value": "[parameters('hikariValidationTimeout')]"
            },
            {
              "name": "JAVA_TOOL_OPTIONS",
              "value": "[parameters('javaToolOptions')]"
            },
            {
              "name": "JDBC_URL",
              "value": "[concat('jdbc:sqlserver://', parameters('serviceDBHost'), ':1433;databaseName=', variables('databaseNameFull'), ';user=', parameters('serviceDBUsernameAD'), ';password=', parameters('serviceDBPasswordAD'), ';trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;encrypt=true;socketTimeout=', parameters('dbSocketTimeout'), ';loginTimeout=', parameters('dbLoginTimeout'), ';authentication=ActiveDirectoryPassword')]"
            },
            {
              "name": "JWT_AUDIENCE",
              "value": "[parameters('jwtAudience')]"
            },
            {
              "name": "JWT_CERT_ISSUER",
              "value": "[variables('proxyUrl')]"
            },
            {
              "name": "JWT_KEY_PRIVATE_B64",
              "value": "[parameters('jwtPrivateKey')]"
            },
            {
              "name": "PERMISSIONS_SERVICE_PASSWORD",
              "value": "[parameters('permissionsServiceBasicAuthPassword')]"
            },
            {
              "name": "RDL_APPROVED_ESTABLISHMENT_CRON_FREQUENCY",
              "value": "[parameters('approvedEstablishmentCronFrequency')]"
            },
            {
              "name": "RDL_COMMODITYCODE_CRON_FREQUENCY",
              "value": "[parameters('commodityCodeCronFrequency')]"
            },
            {
              "name": "REFERENCE_DATA_LOADER_SERVICE_RDS_API_CLIENT",
              "value": "[parameters('rdsApiClient')]"
            },
            {
              "name": "REFERENCE_DATA_LOADER_SERVICE_RDS_API_KEY",
              "value": "[parameters('rdsApiKey')]"
            },
            {
              "name": "REFERENCE_DATA_LOADER_SERVICE_RDS_API_URL",
              "value": "[concat(parameters('rdsApiUrl'), variables('rdsApiEnvDomain'))]"
            },
            {
              "name": "PROTOCOL",
              "value": "https"
            },
            {
              "name": "SECURITY_JWT_AUD",
              "value": "a2617985-5645-47ec-8912-7a943b3895ba"
            },
            {
              "name": "SECURITY_JWT_ISS",
              "value": "[variables('proxyUrl')]"
            },
            {
              "name": "SECURITY_JWT_JWKS",
              "value": "[concat(variables('proxyUrl'), '/common/discovery/keys')]"
            },
            {
              "name": "SERVICE_PORT",
              "value": "4000"
            },
            {
              "name": "TRUST_SERVER_CERTIFICATE",
              "value": "false"
            },
            {
              "name": "WEBSITES_CONTAINER_START_TIME_LIMIT",
              "value": "[parameters('containerStartTimeLimit')]"
            },
            {
              "name": "WEBSITE_HEALTHCHECK_MAXPINGFAILURES",
              "value": "[parameters('healthcheckMaxFailures')]"
            }
          ],
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "healthCheckPath": "/admin/health-check"
        },
        "clientAffinityEnabled": false,
        "httpsOnly": true
      },
      "resources": [
        {
          "type": "config",
          "name": "web",
          "condition": "[not(empty(parameters('WebvNetResourceGroup')))]",
          "apiVersion": "2020-06-01",
          "location": "[resourceGroup().location]",
          "tags": {
            "Name": "[concat(parameters('serviceName'), '/', 'web')]",
            "ServiceCode": "[parameters('serviceCode')]",
            "ServiceName": "[concat(parameters('serviceName'), ' Site Config')]",
            "ServiceType": "LOB",
            "CreationDateTime": "[parameters('dateCreated')]",
            "Environment": "[parameters('envCode')]",
            "Tier": "WEB",
            "Region": "[resourceGroup().location]"
          },
          "scale": null,
          "properties": {
            "httpLoggingEnabled": true,
            "logsDirectorySizeLimit": 35,
            "detailedErrorLoggingEnabled": false,
            "publishingUsername": "[parameters('serviceName')]",
            "alwaysOn": true,
            "ftpsState": "Disabled",
            "healthCheckPath": "/admin/health-check",
            "ipSecurityRestrictions": "[variables('ipSecurityRestrictions')]",
            "scmIpSecurityRestrictions": [
              {
                "ipAddress": "0.0.0.0/0",
                "action": "Deny",
                "priority": 1000,
                "name": "Deny all",
                "description": "Deny all access"
              }
            ],
            "scmIpSecurityRestrictionsUseMain": false
          },
          "dependsOn": [
            "[resourceId('Microsoft.Web/sites', parameters('serviceName'))]"
          ]
        },
        {
          "type": "networkConfig",
          "name": "VirtualNetwork",
          "condition": "[not(empty(parameters('WebvNetResourceGroup')))]",
          "apiVersion": "2020-12-01",
          "properties": {
            "subnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-reference-data-plan-1'))]",
            "swiftSupported": true
          },
          "dependsOn": [
            "[resourceId('Microsoft.Web/sites', parameters('serviceName'))]"
          ]
        }
      ]
    }
  ]
}
