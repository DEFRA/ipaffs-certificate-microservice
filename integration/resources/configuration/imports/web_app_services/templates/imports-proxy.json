            },
            {
              "name": "PROXY_EXTERNAL_ADDRESS_B2C",
              "value": "[parameters('proxyExternalAddressB2C')]"
            },
            {
              "name": "REDIS_HOST",
              "value": "[concat(parameters('redisConfig').cacheName, '.redis.cache.windows.net')]"
            },
            {
              "name": "REDIS_PASSWORD",
              "value": "[if(equals(parameters('envSuffix'), 'vnet'), parameters('redisCacheKey'), listKeys(resourceId(parameters('redisConfig').resourceGroup, 'Microsoft.Cache/Redis', parameters('redisConfig').cacheName), providers('Microsoft.Cache', 'redis').apiVersions[0]).primaryKey)]"
            },
            {
              "name": "REDIS_PORT",
              "value": "[parameters('redisConfig').port]"
            },
