{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "azureSearchApiVersion": {
      "type": "string"
    },
    "azureSearchIndexSuffix": {
      "type": "string"
    },
    "azureSearchServiceAPIKey": {
      "type": "securestring"
    },
    "azureSearchServiceAdminAPIKey": {
      "type": "securestring"
    },
    "azureSearchServiceName": {
      "type": "string"
    },
    "blueGreen": {
      "type": "string"
    },
    "containerStartTimeLimit": {
      "type": "string"
    },
    "containerRepository": {
      "type": "string"
    },
    "databaseName": {
      "type": "string"
    },
    "dateCreated": {
      "type": "string"
    },
    "dbLoginTimeout": {
      "type": "string"
    },
    "dbSocketTimeout": {
      "type": "string"
    },
    "dnsCacheTtl": {
      "type": "string"
    },
    "dnsSuffix": {
      "type": "string"
    },
    "dockerRegistryPassword": {
      "type": "securestring"
    },
    "dockerRegistryServerUrl": {
      "type": "string"
    },
    "dockerRegistryServerUsername": {
      "type": "string"
    },
    "enableDelegationOfAuthority": {
      "type": "string"
    },
    "envCode": {
      "type": "string"
    },
    "envSuffix": {
      "type": "string"
    },
    "healthcheckMaxFailures": {
      "type": "int"
    },
    "euImportIpaffsDynamicsIntegration": {
      "type": "bool"
    },
    "eventHubEnvironment": {
      "type": "string"
    },
    "eventHubKeyName": {
      "type": "string"
    },
    "eventHubKeyValue": {
      "type": "string"
    },
    "eventHubName": {
      "type": "string"
    },
    "eventHubNamespace": {
      "type": "string"
    },
    "hikariDebugLevel": {
      "type": "string"
    },
    "hikariLeakDetectionThreshold": {
      "type": "string"
    },
    "hikariConnectionTimeout": {
      "type": "string"
    },
    "hikariValidationTimeout": {
      "type": "string"
    },
    "javaToolOptions": {
      "type": "string"
    },
    "maximumRecordsRetrievable": {
      "type": "string"
    },
    "monitoringType": {
      "type": "string"
    },
    "permissionsServiceBasicAuthPassword": {
      "type": "securestring"
    },
    "proxyHost": {
      "type": "string"
    },
    "readOnlyDatabase": {
      "type": "bool"
    },
    "recreateAzureSearchIndex": {
      "type": "string"
    },
    "riskLockingSla": {
      "type": "string"
    },
    "serviceBasicAuthPassword": {
      "type": "securestring"
    },
    "serviceCode": {
      "type": "string"
    },
    "serviceDBHost": {
      "type": "string"
    },
    "serviceDBPassword": {
      "type": "securestring"
    },
    "serviceDBPasswordAD": {
      "type": "securestring"
    },
    "serviceDBPasswordNew": {
      "type": "securestring"
    },
    "serviceDBUsername": {
      "type": "string"
    },
    "serviceDBUsernameAD": {
      "type": "string"
    },
    "serviceName": {
      "type": "string"
    },
    "servicePlanGroup": {
      "type": "string"
    },
    "testEndpointsEnabled": {
      "type": "bool"
    },
    "threadPoolKeepAliveSeconds": {
      "type": "string"
    },
    "threadPoolQueueCapacity": {
      "type": "string"
    },
    "tracesNtIntegration": {
      "type": "bool"
    },
    "tradePlatformIntegration": {
      "type": "bool"
    },
    "topicConfig": {
      "type": "object"
    },
    "topicName" : {
      "type": "string",
      "defaultValue": "[concat('sandpit-', parameters('envSuffix'), '-notification-topic')]",
      "metadata": {
        "description": "To use the default value, do not specify a new value."
      }
    },
    "riskFeedbackQueueName" : {
      "type": "string",
      "defaultValue": "risk_feedback_queue",
      "metadata": {
        "description": "To use the default value, do not specify a new value."
      }
    },
    "version": {
      "type": "string"
    },
    "WebvNetResourceGroup": {
      "type": "string"
    },
    "WebvNetName": {
      "type": "string"
    },
    "WebSubnetName-reference-data-plan-1": {
      "type": "string"
    },
    "WebSubnetName-reference-data-plan-2": {
      "type": "string"
    },
    "WebSubnetName-low-traffic-plan-1": {
      "type": "string"
    },
    "WebSubnetName-high-traffic-plan-1": {
      "type": "string"
    },
    "WebSubnetName-frontend-plan-1": {
      "type": "string"
    },
    "WebSubnetName-soap-services-plan-1": {
      "type": "string"
    },
    "DeploymentSubnetResourceId": {
      "type": "string"
    },
    "sharedInfraResourceGroupName": {
      "type": "string"
    },
    "rtlDeploymentCheckSubnetResourceId": {
      "type": "string"
    },
    "maxCommodityLines": {
      "type": "int"
    },
    "chedppTempPodRemovalUtcDate": {
      "type": "string"
    },
    "chedppArticle72TransitionDateTime": {
      "type": "string"
    },
    "chedppEuHarmonisationTransitionDateTime": {
      "type": "string"
    }
  },
  "variables": {
    "appInsightsName": "[concat('insights-',if(empty(parameters('sharedInfraResourceGroupName')), resourceGroup().name, parameters('sharedInfraResourceGroupName')), if(not(empty(parameters('blueGreen'))), concat('-', parameters('blueGreen')),''))]",
    "azureSearchIndexName": "[if(empty(parameters('blueGreen')), concat(parameters('envSuffix'), '-', parameters('azureSearchIndexSuffix')), concat(parameters('blueGreen'), '-', parameters('envCode'), '-', parameters('azureSearchIndexSuffix')))]",
    "databaseNameFull": "[if(empty(parameters('blueGreen')), concat(parameters('databaseName'), '-', parameters('envSuffix')), parameters('databaseName'))]",
    "dockerCustomImageName": "[concat(parameters('dockerRegistryServerUrl'), '/', parameters('containerRepository'), '/', 'notification-microservice', ':', parameters('version'))]",
    "envDomain": "[if(empty(parameters('blueGreen')), concat('-', parameters('envSuffix'),  parameters('dnsSuffix')), concat('-', parameters('blueGreen'), parameters('dnsSuffix')))]",
    "proxyUrl": "[concat('https://', parameters('proxyHost'), parameters('dnsSuffix'))]",
    "servicePlanName": "[if(empty(parameters('blueGreen')), concat(parameters('servicePlanGroup'), '-', parameters('envSuffix')), parameters('servicePlanGroup'))]",
    "topicName": "[if(equals(parameters('envCode'), 'HFX'), 'hotfix-notification-topic', parameters('topicName'))]",
    "riskFeedbackQueueName": "[if(empty(parameters('blueGreen')), concat('dev', '_', parameters('riskFeedbackQueueName'), '_', parameters('envSuffix')), parameters('riskFeedbackQueueName'))]",
    "ipSecurityRestrictions": "[if(equals(parameters('envSuffix'), 'vnet'), union(variables('vnetIpSecurityRestrictions'), variables('commonIpSecurityRestrictions')), union(variables('commonIpSecurityRestrictions'), variables('rtlIpSecurityRestrictions')))]",
    "vnetIpSecurityRestrictions":
        [
          {
              "ipAddress": "195.89.171.5/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 120,
              "name": "KainosVPN1",
              "description": "Allow access from Kainos VPN1"
          },
          {
              "ipAddress": "195.89.171.144/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 121,
              "name": "KainosVPN2",
              "description": "Allow access from Kainos VPN2"
          },
          {
              "ipAddress": "62.254.63.52/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 122,
              "name": "KainosVPN3",
              "description": "Allow access from Kainos VPN3"
          },
          {
              "vnetSubnetResourceId": "[if(empty(parameters('DeploymentSubnetResourceId')), resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-soap-services-plan-1')), parameters('DeploymentSubnetResourceId'))]",
              "action": "Allow",
              "tag": "Default",
              "priority": 107,
              "name": "AllowDeploymentChecks"
          }
        ],
    "rtlIpSecurityRestrictions":
        [
            {
                "vnetSubnetResourceId": "[parameters('rtlDeploymentCheckSubnetResourceId')]",
                "action": "Allow",
                "tag": "Default",
                "priority": 109,
                "name": "AllowRtlDeploymentChecks"
            }
        ],
    "commonIpSecurityRestrictions":
        [
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-reference-data-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 101,
                "name": "AllowReferenceDataPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-reference-data-plan-2'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 102,
                "name": "AllowReferenceDataPlan2"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-low-traffic-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 103,
                "name": "AllowLowTrafficPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-high-traffic-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 104,
                "name": "AllowHighTrafficPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-frontend-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 105,
                "name": "AllowFrontendPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-soap-services-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 106,
                "name": "AllowSoapServicesPlan1"
            },
            {
                "ipAddress": "Any",
                "action": "Deny",
                "priority": 2147483647,
                "name": "Deny all",
                "description": "Deny all access"
            }
        ]
    },
  "resources": [
    {
      "name": "[parameters('serviceName')]",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2020-12-01",
      "location": "[resourceGroup().location]",
      "tags": {
        "Name": "[parameters('serviceName')]",
        "ServiceCode": "[parameters('serviceCode')]",
        "ServiceName": "[concat('EUX Imports:', parameters('serviceName'))]",
        "ServiceType": "LOB",
        "CreationDateTime": "[parameters('dateCreated')]",
        "Environment": "[parameters('envCode')]",
        "Tier": "WEB",
        "Region": "[resourceGroup().location]"
      },
      "properties": {
        "name": "[parameters('serviceName')]",
        "serverFarmId": "[concat(resourceGroup().id, '/providers/Microsoft.Web/serverfarms/', variables('servicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', variables('dockerCustomImageName'))]",
          "httpLoggingEnabled": true,
          "logsDirectorySizeLimit": 35,
          "detailedErrorLoggingEnabled": false,
          "publishingUsername": "[parameters('serviceName')]",
          "appSettings": [
            {
              "name": "WEBSITE_VNET_ROUTE_ALL",
              "value": "[if(empty(parameters('WebvNetResourceGroup')), '0', '1')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId(if(empty(parameters('sharedInfraResourceGroupName')), resourceGroup().name, parameters('sharedInfraResourceGroupName')), 'Microsoft.Insights/components', variables('appInsightsName')), '2015-05-01').ConnectionString]"
            },
            {
              "name": "AUTOMATIC_TRANSITION_ENABLED",
              "value": "false"
            },
            {
              "name": "AZURE_SEARCH_ADMIN_API_KEY",
              "value": "[parameters('azureSearchServiceAdminAPIKey')]"
            },
            {
              "name": "AZURE_SEARCH_API_VERSION",
              "value": "[parameters('azureSearchApiVersion')]"
            },
            {
              "name": "AZURE_SEARCH_INDEX_NAME",
              "value": "[variables('azureSearchIndexName')]"
            },
            {
              "name": "AZURE_SEARCH_QUERY_KEY",
              "value": "[parameters('azureSearchServiceAPIKey')]"
            },
            {
              "name": "AZURE_SEARCH_SERVICE_NAME",
              "value": "[parameters('azureSearchServiceName')]"
            },
            {
              "name": "CREATE_AUDIT_ENABLED",
              "value": "true"
            },
            {
              "name": "DATE_DEPLOYED",
              "value": "[parameters('dateCreated')]"
            },
            {
              "name": "DB_HOST",
              "value": "[parameters('serviceDBHost')]"
            },
            {
              "name": "DB_LOGIN_TIMEOUT",
              "value": "[parameters('dbLoginTimeout')]"
            },
            {
              "name": "DB_NAME",
              "value": "[variables('databaseNameFull')]"
            },
            {
              "name": "DB_PASSWORD",
              "value": "[parameters('serviceDBPassword')]"
            },
            {
              "name": "DB_PASSWORD_AD",
              "value": "[parameters('serviceDBPasswordAD')]"
            },
            {
              "name": "DB_PASSWORD_NEW",
              "value": "[parameters('serviceDBPasswordNew')]"
            },
            {
              "name": "DB_PORT",
              "value": "1433"
            },
            {
              "name": "DB_SOCKET_TIMEOUT",
              "value": "[parameters('dbSocketTimeout')]"
            },
            {
              "name": "DB_USER",
              "value": "[parameters('serviceDBUsername')]"
            },
            {
              "name": "DB_USER_AD",
              "value": "[parameters('serviceDBUsernameAD')]"
            },
            {
              "name": "DNS_CACHE_TTL",
              "value": "[parameters('dnsCacheTtl')]"
            },
            {
              "name": "DELETE_AUDIT_ENABLED",
              "value": "false"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('dockerRegistryPassword')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[parameters('dockerRegistryServerUrl')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[parameters('dockerRegistryServerUsername')]"
            },
            {
              "name": "ENABLE_DELEGATION_OF_AUTHORITY",
              "value": "[parameters('enableDelegationOfAuthority')]"
            },
            {
              "name": "ENV_DOMAIN",
              "value": "[variables('envDomain')]"
            },
            {
              "name": "EU_IMPORT_IPAFFS_DYNAMICS_INTEGRATION",
              "value": "[parameters('euImportIpaffsDynamicsIntegration')]"
            },
            {
              "name": "EVENT_HUB_ENVIRONMENT",
              "value": "[parameters('eventHubEnvironment')]"
            },
            {
              "name": "EVENT_HUB_KEY_NAME",
              "value": "[parameters('eventHubKeyName')]"
            },
            {
              "name": "EVENT_HUB_KEY_VALUE",
              "value": "[parameters('eventHubKeyValue')]"
            },
            {
              "name": "EVENT_HUB_NAME",
              "value": "[parameters('eventHubName')]"
            },
            {
              "name": "EVENT_HUB_NAMESPACE",
              "value": "[parameters('eventHubNamespace')]"
            },
            {
              "name": "FAILURE_RATE_THRESHOLD",
              "value": "50"
            },
            {
              "name": "HIKARI_CONNECTION_POOL_SIZE",
              "value": "50"
            },
            {
              "name": "HIKARI_DEBUG_LEVEL",
              "value": "[parameters('hikariDebugLevel')]"
            },
            {
              "name": "HIKARI_LEAK_DETECTION_THRESHOLD",
              "value": "[parameters('hikariLeakDetectionThreshold')]"
            },
            {
              "name": "HIKARI_CONNECTION_TIMEOUT",
              "value": "[parameters('hikariConnectionTimeout')]"
            },
            {
              "name": "HIKARI_VALIDATION_TIMEOUT",
              "value": "[parameters('hikariValidationTimeout')]"
            },
            {
              "name": "JAVA_TOOL_OPTIONS",
              "value": "[parameters('javaToolOptions')]"
            },
            {
              "name": "JDBC_URL",
              "value": "[concat('jdbc:sqlserver://', parameters('serviceDBHost'), ':1433;databaseName=', variables('databaseNameFull'), ';user=', parameters('serviceDBUsernameAD'), ';password=', parameters('serviceDBPasswordAD'), ';trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;encrypt=true;socketTimeout=', parameters('dbSocketTimeout'), ';loginTimeout=', parameters('dbLoginTimeout'), ';authentication=ActiveDirectoryPassword')]"
            },
            {
              "name": "MIN_NUMBER_OF_CALLS",
              "value": "10"
            },
            {
              "name": "MAXIMUM_RECORDS_RETRIEVABLE",
              "value": "[parameters('maximumRecordsRetrievable')]"
            },
            {
              "name": "MONITORING_TYPE",
              "value": "[parameters('monitoringType')]"
            },
            {
              "name": "NOTIFICATION_TEST_ENDPOINTS_ENABLED",
              "value": "[parameters('testEndpointsEnabled')]"
            },
            {
              "name": "PERMISSIONS_SERVICE_PASSWORD",
              "value": "[parameters('permissionsServiceBasicAuthPassword')]"
            },
            {
              "name": "PERMITTED_CALLS_WHEN_HALF_OPEN",
              "value": "10"
            },
            {
              "name": "READ_AUDIT_ENABLED",
              "value": "true"
            },
            {
              "name": "PROTOCOL",
              "value": "https"
            },
            {
              "name": "RISK_FEEDBACK_QUEUE_NAME",
              "value": "[variables('riskFeedbackQueueName')]"
            },
            {
              "name": "RISK_LOCKING_SLA",
              "value": "[parameters('riskLockingSla')]"
            },
            {
              "name": "SERVICE_BUS_TOPIC_NAME",
              "value": "[variables('topicName')]"
            },
            {
              "name": "SECURITY_JWT_AUD",
              "value": "a2617985-5645-47ec-8912-7a943b3895ba"
            },
            {
              "name": "SECURITY_JWT_ISS",
              "value": "[variables('proxyUrl')]"
            },
            {
              "name": "SECURITY_JWT_JWKS",
              "value": "[concat(variables('proxyUrl'), '/common/discovery/keys')]"
            },
            {
              "name": "SERVICE_PASSWORD",
              "value": "[parameters('serviceBasicAuthPassword')]"
            },
            {
              "name": "SERVICE_PORT",
              "value": "8080"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8080"
            },
            {
              "name": "SLIDING_WINDOW_SIZE",
              "value": "20"
            },
            {
              "name": "SLOW_CALL_DURATION_THRESHOLD",
              "value": "3000"
            },
            {
              "name": "SLOW_CALL_RATE_THRESHOLD",
              "value": "50"
            },
            {
              "name": "THREAD_POOL_KEEP_ALIVE_SECONDS",
              "value": "[parameters('threadPoolKeepAliveSeconds')]"
            },
            {
              "name": "THREAD_POOL_QUEUE_CAPACITY",
              "value": "[parameters('threadPoolQueueCapacity')]"
            },
            {
              "name": "TOPIC_CONNECTION_STRING",
              "value": "[listKeys(resourceId(parameters('topicConfig').resourceGroup, 'Microsoft.ServiceBus/namespaces/authorizationRules', parameters('topicConfig').name, parameters('topicConfig').sasPolicy), parameters('topicConfig').apiVersion).primaryConnectionString]"
            },
            {
              "name": "TRACES_NT_INTEGRATION",
              "value": "[parameters('tracesNtIntegration')]"
            },
            {
              "name": "TRADE_PLATFORM_INTEGRATION",
              "value": "[parameters('tradePlatformIntegration')]"
            },
            {
              "name": "TRUST_SERVER_CERTIFICATE",
              "value": "false"
            },
            {
              "name": "UPDATE_AUDIT_ENABLED",
              "value": "true"
            },
            {
              "name": "WAIT_DURATION_IN_OPEN_STATE",
              "value": "300000"
            },
            {
              "name": "WEBSITES_CONTAINER_START_TIME_LIMIT",
              "value": "[parameters('containerStartTimeLimit')]"
            },
            {
              "name": "WEBSITE_HEALTHCHECK_MAXPINGFAILURES",
              "value": "[parameters('healthcheckMaxFailures')]"
            },
            {
              "name": "MAX_COMMODITY_LINES",
              "value": "[parameters('maxCommodityLines')]"
            },
            {
              "name": "CHEDPP_TEMP_POD_REMOVAL_UTC_DATE",
              "value": "[parameters('chedppTempPodRemovalUtcDate')]"
            },
            {
              "name": "CHEDPP_ARTICLE_72_TRANSITION_DATE_TIME",
              "value": "[parameters('chedppArticle72TransitionDateTime')]"
            },
            {
              "name": "CHEDPP_EU_HARMONISATION_TRANSITION_DATE_TIME",
              "value": "[parameters('chedppEuHarmonisationTransitionDateTime')]"
            }
          ],
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "healthCheckPath": "/admin/health-check"
        },
        "clientAffinityEnabled": false,
        "httpsOnly": true
      },
      "resources": [
        {
          "type": "config",
          "name": "web",
          "condition": "[not(empty(parameters('WebvNetResourceGroup')))]",
          "apiVersion": "2020-06-01",
          "location": "[resourceGroup().location]",
          "tags": {
            "Name": "[concat(parameters('serviceName'), '/', 'web')]",
            "ServiceCode": "[parameters('serviceCode')]",
            "ServiceName": "[concat(parameters('serviceName'), ' Site Config')]",
            "ServiceType": "LOB",
            "CreationDateTime": "[parameters('dateCreated')]",
            "Environment": "[parameters('envCode')]",
            "Tier": "WEB",
            "Region": "[resourceGroup().location]"
          },
          "scale": null,
          "properties": {
            "httpLoggingEnabled": true,
            "logsDirectorySizeLimit": 35,
            "detailedErrorLoggingEnabled": false,
            "publishingUsername": "[parameters('serviceName')]",
            "alwaysOn": true,
            "ftpsState": "Disabled",
            "healthCheckPath": "/admin/health-check",
            "ipSecurityRestrictions": "[variables('ipSecurityRestrictions')]",
            "scmIpSecurityRestrictions": [
              {
                "ipAddress": "0.0.0.0/0",
                "action": "Deny",
                "priority": 1000,
                "name": "Deny all",
                "description": "Deny all access"
              }
            ],
            "scmIpSecurityRestrictionsUseMain": false
          },
          "dependsOn": [
            "[resourceId('Microsoft.Web/sites', parameters('serviceName'))]"
          ]
        },
        {
          "type": "networkConfig",
          "name": "VirtualNetwork",
          "condition": "[not(empty(parameters('WebvNetResourceGroup')))]",
          "apiVersion": "2020-12-01",
          "properties": {
            "subnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-high-traffic-plan-1'))]",
            "swiftSupported": true
          },
          "dependsOn": [
            "[resourceId('Microsoft.Web/sites', parameters('serviceName'))]"
          ]
        }
      ]
    }
  ]
}
