    "soapSearchServiceFelixstowePhilisPassword": {
      "type": "securestring"
    },
    "soapSearchServiceFsaUserPassword": {
      "type": "securestring"
    },
    "soapSearchServiceIsc1Password": {
      "type": "securestring"
    },
    "soapSearchServiceIsc2Password": {
      "type": "securestring"
    },
    "soapSearchServiceLhrPhilisPassword": {
      "type": "securestring"
    },
    "soapSearchServiceLiverpoolPhilisPassword": {
      "type": "securestring"
    },
    "soapSearchServiceLondonPhilisPassword": {
      "type": "securestring"
    },
    "soapSearchServiceSouthamptonPhilisPassword": {
      "type": "securestring"
