            {
              "name": "SOAP_SEARCH_SERVICE_LHR_PHILIS_PASSWORD",
              "value": "[parameters('soapSearchServiceLhrPhilisPassword')]"
            },
            {
              "name": "SOAP_SEARCH_SERVICE_LHR_PHILIS_USER_ID",
              "value": "LHR_PHILIS"
