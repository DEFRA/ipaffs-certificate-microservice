          "ftpsState": "Disabled",
          "healthCheckPath": "/admin/health-check"
        },
        "clientAffinityEnabled": false,
        "httpsOnly": true
      },
      "resources": [
        {
          "type": "config",
          "name": "web",
          "condition": "[not(empty(parameters('WebvNetResourceGroup')))]",
          "apiVersion": "2020-06-01",
          "location": "[resourceGroup().location]",
          "tags": {
            "Name": "[concat(parameters('serviceName'), '/', 'web')]",
            "ServiceCode": "[parameters('serviceCode')]",
            "ServiceName": "[concat(parameters('serviceName'), ' Site Config')]",
            "ServiceType": "LOB",
            "CreationDateTime": "[parameters('dateCreated')]",
            "Environment": "[parameters('envCode')]",
            "Tier": "WEB",
            "Region": "[resourceGroup().location]"
          },
          "scale": null,
          "properties": {
            "httpLoggingEnabled": true,
            "logsDirectorySizeLimit": 35,
            "detailedErrorLoggingEnabled": false,
            "publishingUsername": "[parameters('serviceName')]",
            "alwaysOn": true,
            "ftpsState": "Disabled",
            "healthCheckPath": "/admin/health-check",
            "ipSecurityRestrictions": "[variables('ipSecurityRestrictions')]",
            "scmIpSecurityRestrictions": [
              {
                "ipAddress": "0.0.0.0/0",
