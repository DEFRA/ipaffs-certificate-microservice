{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "allowedIPAFFSCountries": {
      "type": "string"
    },
    "archivePeriodChedpp": {
      "type": "string"
    },
    "archivePeriodOtherChed": {
      "type": "string"
    },
    "bcpNameOverrides": {
      "type": "string"
    },
    "blueGreen": {
      "type": "string"
    },
    "containerStartTimeLimit": {
      "type": "string"
    },
    "containerRepository": {
      "type": "string"
    },
    "countriesCacheTimeout": {
      "type": "string"
    },
    "dateCreated": {
      "type": "string"
    },
    "dnsSuffix": {
      "type": "string"
    },
    "dockerRegistryPassword": {
      "type": "securestring"
    },
    "dockerRegistryServerUrl": {
      "type": "string"
    },
    "dockerRegistryServerUsername": {
      "type": "string"
    },
    "enableCHEDPP": {
      "type": "string"
    },
    "enableChedppAdditionalMeansOfTransport": {
      "type": "string"
    },
    "enableChedppRiskAssessmentOnSubmission": {
      "type": "string"
    },
    "chedppPiecesQuantityType": {
      "type": "string"
    },
    "enableCloning": {
      "type": "string"
    },
    "enableEPhytoCloning": {
      "type": "string"
    },
    "enableLiveAnimalCloning": {
      "type": "string"
    },
    "enableChedpCloningEuCountries": {
      "type": "string"
    },
    "enableChedppOptionalContainerNumber": {
      "type": "string"
    },
    "enableChedppOptionalSealNumber": {
      "type": "string"
    },
    "enableDatePicker": {
      "type": "string"
    },
    "enableDelegationOfAuthority": {
      "type": "string"
    },
    "enableEnhancedLowRiskJourney": {
      "type": "string"
    },
    "enableEuImportsHighRiskJourney": {
      "type": "string"
    },
    "enableEuImportsHighRiskJourneyCheda": {
      "type": "string"
    },
    "enableEuChedAssessmentSubmission" : {
      "type": "string"
    },
    "enableGenusSpeciesSearch": {
      "type": "string"
    },
    "enableNotificationArchive" : {
      "type": "string"
    },
    "enablePostEuxSupport": {
      "type": "string"
    },
    "envCode": {
      "type": "string"
    },
    "envSuffix": {
      "type": "string"
    },
    "healthcheckMaxFailures": {
      "type": "int"
    },
    "feedbackSurveyLink": {
      "type": "string"
    },
    "googleTagManagerID": {
      "type": "string"
    },
    "hexEncryptionKey": {
      "type": "securestring"
    },
    "nodeOptions": {
      "type": "string"
    },
    "permissionsServiceBasicAuthPassword": {
      "type": "securestring"
    },
    "proxyHost": {
      "type": "string"
    },
    "serviceCode": {
      "type": "string"
    },
    "serviceName": {
      "type": "string"
    },
    "servicePlanGroup": {
      "type": "string"
    },
    "serviceUser": {
      "type": "string"
    },
    "showTrainingBanner": {
      "defaultValue": false,
      "type": "bool"
    },
    "version": {
      "type": "string"
    },
    "WebvNetResourceGroup": {
      "type": "string"
    },
    "WebvNetName": {
      "type": "string"
    },
    "WebSubnetName-reference-data-plan-1": {
      "type": "string"
    },
    "WebSubnetName-reference-data-plan-2": {
      "type": "string"
    },
    "WebSubnetName-low-traffic-plan-1": {
      "type": "string"
    },
    "WebSubnetName-high-traffic-plan-1": {
      "type": "string"
    },
    "WebSubnetName-frontend-plan-1": {
      "type": "string"
    },
    "WebSubnetName-soap-services-plan-1": {
      "type": "string"
    },
    "DeploymentSubnetResourceId": {
      "type": "string"
    },
    "sharedInfraResourceGroupName": {
      "type": "string"
    },
    "rtlDeploymentCheckSubnetResourceId": {
      "type": "string"
    },
    "redisHost": {
      "type": "string"
    },
    "redisPort": {
      "type": "int"
    },
    "redisPassword": {
      "type": "securestring"
    },
    "enableCHEDADocImprovements": {
      "type": "string"
    },
    "enableChedppCsvBulkUpload": {
      "type": "string"
    },
    "enableLowRiskArticle72": {
      "type": "string"
    },
    "maxCommodityLines": {
      "type": "int"
    },
    "chedppTempPodRemovalUtcDate": {
      "type": "string"
    },
    "chedppArticle72TransitionDateTime": {
      "type": "string"
    },
    "chedppEuHarmonisationTransitionDateTime": {
      "type": "string"
    },
    "enableMultiDocumentUpload": {
      "type": "string"
    }
  },
  "variables": {
    "appInsightsName": "[concat('insights-',if(empty(parameters('sharedInfraResourceGroupName')), resourceGroup().name, parameters('sharedInfraResourceGroupName')), if(not(empty(parameters('blueGreen'))), concat('-', parameters('blueGreen')),''))]",
    "dockerCustomImageName": "[concat(parameters('dockerRegistryServerUrl'), '/', parameters('containerRepository'), '/', 'frontend-notification', ':', parameters('version'))]",
    "envDomain": "[if(empty(parameters('blueGreen')), concat('-', parameters('envSuffix'),  parameters('dnsSuffix')), concat('-', parameters('blueGreen'), parameters('dnsSuffix')))]",
    "frontendHostname": "[concat(parameters('serviceName'), '.azurewebsites.net')]",
    "proxyUrl": "[concat('https://', parameters('proxyHost'), parameters('dnsSuffix'))]",
    "servicePlanName": "[if(empty(parameters('blueGreen')), concat(parameters('servicePlanGroup'), '-', parameters('envSuffix')), parameters('servicePlanGroup'))]",
    "ipSecurityRestrictions": "[if(equals(parameters('envSuffix'), 'vnet'), union(variables('vnetIpSecurityRestrictions'), variables('commonIpSecurityRestrictions')), union(variables('commonIpSecurityRestrictions'), variables('rtlIpSecurityRestrictions')))]",
    "vnetIpSecurityRestrictions":
        [
          {
              "ipAddress": "195.89.171.5/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 120,
              "name": "KainosVPN1",
              "description": "Allow access from Kainos VPN1"
          },
          {
              "ipAddress": "195.89.171.144/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 121,
              "name": "KainosVPN2",
              "description": "Allow access from Kainos VPN2"
          },
          {
              "ipAddress": "62.254.63.52/32",
              "action": "Allow",
              "tag": "Default",
              "priority": 122,
              "name": "KainosVPN3",
              "description": "Allow access from Kainos VPN3"
          },
          {
              "vnetSubnetResourceId": "[if(empty(parameters('DeploymentSubnetResourceId')), resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-soap-services-plan-1')), parameters('DeploymentSubnetResourceId'))]",
              "action": "Allow",
              "tag": "Default",
              "priority": 107,
              "name": "AllowDeploymentChecks"
          }
        ],
    "rtlIpSecurityRestrictions":
        [
            {
                "vnetSubnetResourceId": "[parameters('rtlDeploymentCheckSubnetResourceId')]",
                "action": "Allow",
                "tag": "Default",
                "priority": 109,
                "name": "AllowRtlDeploymentChecks"
            }
        ],
    "commonIpSecurityRestrictions":
        [
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-reference-data-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 101,
                "name": "AllowReferenceDataPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-reference-data-plan-2'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 102,
                "name": "AllowReferenceDataPlan2"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-low-traffic-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 103,
                "name": "AllowLowTrafficPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-high-traffic-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 104,
                "name": "AllowHighTrafficPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-frontend-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 105,
                "name": "AllowFrontendPlan1"
            },
            {
                "vnetSubnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-soap-services-plan-1'))]",
                "action": "Allow",
                "tag": "Default",
                "priority": 106,
                "name": "AllowSoapServicesPlan1"
            },
            {
                "ipAddress": "Any",
                "action": "Deny",
                "priority": 2147483647,
                "name": "Deny all",
                "description": "Deny all access"
            }
        ]
    },
  "resources": [
    {
      "name": "[parameters('serviceName')]",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2020-12-01",
      "location": "[resourceGroup().location]",
      "tags": {
        "Name": "[parameters('serviceName')]",
        "ServiceCode": "[parameters('serviceCode')]",
        "ServiceName": "[concat('EUX Imports:', parameters('serviceName'))]",
        "ServiceType": "LOB",
        "CreationDateTime": "[parameters('dateCreated')]",
        "Environment": "[parameters('envCode')]",
        "Tier": "WEB",
        "Region": "[resourceGroup().location]"
      },
      "properties": {
        "name": "[parameters('serviceName')]",
        "serverFarmId": "[concat(resourceGroup().id, '/providers/Microsoft.Web/serverfarms/', variables('servicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', variables('dockerCustomImageName'))]",
          "httpLoggingEnabled": true,
          "logsDirectorySizeLimit": 35,
          "detailedErrorLoggingEnabled": false,
          "publishingUsername": "[parameters('serviceName')]",
          "appSettings": [
            {
              "name": "WEBSITE_VNET_ROUTE_ALL",
              "value": "[if(empty(parameters('WebvNetResourceGroup')), '0', '1')]"
            },
            {
              "name":  "ARCHIVE_PERIOD_CHEDPP",
              "value": "[parameters('archivePeriodChedpp')]"
            },
            {
              "name":  "ARCHIVE_PERIOD_OTHER_CHED",
              "value": "[parameters('archivePeriodOtherChed')]"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId(if(empty(parameters('sharedInfraResourceGroupName')), resourceGroup().name, parameters('sharedInfraResourceGroupName')), 'Microsoft.Insights/components', variables('appInsightsName')), '2014-04-01').InstrumentationKey]"
            },
            {
              "name": "BCP_NAME_OVERRIDES",
              "value": "[parameters('bcpNameOverrides')]"
            },
            {
              "name": "COUNTRIES_CACHE_TIMEOUT",
              "value": "[parameters('countriesCacheTimeout')]"
            },
            {
              "name": "DATE_DEPLOYED",
              "value": "[parameters('dateCreated')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('dockerRegistryPassword')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[parameters('dockerRegistryServerUrl')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[parameters('dockerRegistryServerUsername')]"
            },
            {
              "name": "ENABLE_CHEDA_DOC_IMPROVEMENTS",
              "value": "[parameters('enableCHEDADocImprovements')]"
            },
            {
              "name": "ENABLE_CHEDPP",
              "value": "[parameters('enableCHEDPP')]"
            },
            {
              "name": "ENABLE_MULTI_DOCUMENT_UPLOAD",
              "value": "[parameters('enableMultiDocumentUpload')]"
            },
            {
              "name": "ENABLE_CHEDPP_ADDITIONAL_MEANS_OF_TRANSPORT",
              "value": "[parameters('enableChedppAdditionalMeansOfTransport')]"
            },
            {
              "name": "ENABLE_CHEDPP_RISK_ASSESSMENT_ON_SUBMISSION",
              "value": "[parameters('enableChedppRiskAssessmentOnSubmission')]"
            },
            {
              "name": "ENABLE_CHEDPP_PIECES_QUANTITY_TYPE",
              "value": "[parameters('chedppPiecesQuantityType')]"
            },
            {
              "name": "ENABLE_CLONING",
              "value": "[parameters('enableCloning')]"
            },
            {
              "name": "ENABLE_EPHYTO_CLONING",
              "value": "[parameters('enableEPhytoCloning')]"
            },
            {
              "name": "ENABLE_LIVE_ANIMAL_CLONING",
              "value": "[parameters('enableLiveAnimalCloning')]"
            },
            {
              "name": "ENABLE_CHEDP_CLONING_EU_COUNTRIES",
              "value": "[parameters('enableChedpCloningEuCountries')]"
            },
            {
              "name": "ENABLE_CHEDPP_OPTIONAL_CONTAINER_NUMBER",
              "value": "[parameters('enableChedppOptionalContainerNumber')]"
            },
            {
              "name": "ENABLE_CHEDPP_OPTIONAL_SEAL_NUMBER",
              "value": "[parameters('enableChedppOptionalSealNumber')]"
            },
            {
              "name": "ENABLE_DATE_PICKER",
              "value": "[parameters('enableDatePicker')]"
            },
            {
              "name": "ENABLE_DELEGATION_OF_AUTHORITY",
              "value": "[parameters('enableDelegationOfAuthority')]"
            },
            {
              "name": "ENABLE_ENHANCED_LOW_RISK_JOURNEY",
              "value": "[parameters('enableEnhancedLowRiskJourney')]"
            },
            {
              "name": "ENABLE_EU_IMPORTS_HIGH_RISK_JOURNEY",
              "value": "[parameters('enableEuImportsHighRiskJourney')]"
            },
            {
              "name": "ENABLE_EU_IMPORTS_HIGH_RISK_JOURNEY_CHEDA",
              "value": "[parameters('enableEuImportsHighRiskJourneyCheda')]"
            },
            {
              "name": "ENABLE_EU_CHED_ASSESSMENT_SUBMISSION",
              "value": "[parameters('enableEuChedAssessmentSubmission')]"
            },
            {
              "name": "ENABLE_GENUS_SPECIES_SEARCH",
              "value": "[parameters('enableGenusSpeciesSearch')]"
            },
            {
              "name": "ENABLE_NOTIFICATION_ARCHIVE",
              "value":  "[parameters('enableNotificationArchive')]"
            },
            {
              "name": "ENABLE_POST_EUX_SUPPORT",
              "value": "[parameters('enablePostEuxSupport')]"
            },
            {
              "name": "ENV_DOMAIN",
              "value": "[variables('envDomain')]"
            },
            {
              "name": "FEEDBACK_SURVEY_LINK",
              "value": "[parameters('feedbackSurveyLink')]"
            },
            {
              "name": "FRONTEND_HOST",
              "value": "[variables('frontendHostname')]"
            },
            {
              "name": "GOOGLE_TAG_MANAGER_ID",
              "value": "[parameters('googleTagManagerID')]"
            },
            {
              "name": "HEX_ENCRYPTION_KEY",
              "value": "[parameters('hexEncryptionKey')]"
            },
            {
              "name": "JWT_CERT_ISSUER",
              "value": "[variables('proxyUrl')]"
            },
            {
              "name": "JWT_CLIENT_ID",
              "value": "a2617985-5645-47ec-8912-7a943b3895ba"
            },
            {
              "name": "JWT_WELL_KNOWNS",
              "value": "[concat(variables('proxyUrl'), '/.well-known/openid-configuration')]"
            },
            {
              "name": "NODE_ENV",
              "value": "production"
            },
            {
              "name": "NODE_OPTIONS",
              "value": "[parameters('nodeOptions')]"
            },
            {
              "name": "PERMISSIONS_SERVICE_BASIC_AUTH_LOGIN",
              "value": "[parameters('serviceUser')]"
            },
            {
              "name": "PERMISSIONS_SERVICE_BASIC_AUTH_PASSWORD",
              "value": "[parameters('permissionsServiceBasicAuthPassword')]"
            },
            {
              "name": "ALLOWED_IPAFFS_COUNTRIES",
              "value": "[parameters('allowedIPAFFSCountries')]"
            },
            {
              "name": "PROTOCOL",
              "value": "https"
            },
            {
              "name": "CERTIFICATE_BASE_PORT",
              "value": "443"
            },
            {
              "name": "SCHEME",
              "value": "https"
            },
            {
              "name": "SHOW_TRAINING_BANNER",
              "value": "[parameters('showTrainingBanner')]"
            },
            {
              "name": "WEBSITES_CONTAINER_START_TIME_LIMIT",
              "value": "[parameters('containerStartTimeLimit')]"
            },
            {
              "name": "WEBSITE_HEALTHCHECK_MAXPINGFAILURES",
              "value": "[parameters('healthcheckMaxFailures')]"
            },
            {
              "name": "REDIS_HOST",
              "value": "[parameters('redisHost')]"
            },
            {
              "name": "REDIS_PORT",
              "value": "[parameters('redisPort')]"
            },
            {
              "name": "REDIS_PASSWORD",
              "value": "[parameters('redisPassword')]"
            },
            {
              "name": "ENABLE_CHEDPP_CSV_BULK_UPLOAD",
              "value": "[parameters('enableChedppCsvBulkUpload')]"
            },
            {
              "name": "ENABLE_LOW_RISK_ARTICLE_72",
              "value": "[parameters('enableLowRiskArticle72')]"
            },
            {
              "name": "MAX_COMMODITY_LINES",
              "value": "[parameters('maxCommodityLines')]"
            },
            {
              "name": "CHEDPP_TEMP_POD_REMOVAL_UTC_DATE",
              "value": "[parameters('chedppTempPodRemovalUtcDate')]"
            },
            {
              "name": "CHEDPP_ARTICLE_72_TRANSITION_DATE_TIME",
              "value": "[parameters('chedppArticle72TransitionDateTime')]"
            },
            {
              "name": "CHEDPP_EU_HARMONISATION_TRANSITION_DATE_TIME",
              "value": "[parameters('chedppEuHarmonisationTransitionDateTime')]"
            }
          ],
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "healthCheckPath": "/admin/health-check"
        },
        "clientAffinityEnabled": false,
        "httpsOnly": true
      },
      "resources": [
                {
          "type": "config",
          "name": "web",
          "condition": "[not(empty(parameters('WebvNetResourceGroup')))]",
          "apiVersion": "2020-06-01",
          "location": "[resourceGroup().location]",
          "tags": {
            "Name": "[concat(parameters('serviceName'), '/', 'web')]",
            "ServiceCode": "[parameters('serviceCode')]",
            "ServiceName": "[concat(parameters('serviceName'), ' Site Config')]",
            "ServiceType": "LOB",
            "CreationDateTime": "[parameters('dateCreated')]",
            "Environment": "[parameters('envCode')]",
            "Tier": "WEB",
            "Region": "[resourceGroup().location]"
          },
          "scale": null,
          "properties": {
            "httpLoggingEnabled": true,
            "logsDirectorySizeLimit": 35,
            "detailedErrorLoggingEnabled": false,
            "publishingUsername": "[parameters('serviceName')]",
            "alwaysOn": true,
            "ftpsState": "Disabled",
            "healthCheckPath": "/admin/health-check",
            "ipSecurityRestrictions": "[variables('ipSecurityRestrictions')]",
            "scmIpSecurityRestrictions": [
              {
                "ipAddress": "0.0.0.0/0",
                "action": "Deny",
                "priority": 1000,
                "name": "Deny all",
                "description": "Deny all access"
              }
            ],
            "scmIpSecurityRestrictionsUseMain": false
          },
          "dependsOn": [
            "[resourceId('Microsoft.Web/sites', parameters('serviceName'))]"
          ]
        },
        {
          "type": "networkConfig",
          "name": "VirtualNetwork",
          "condition": "[not(empty(parameters('WebvNetResourceGroup')))]",
          "apiVersion": "2020-12-01",
          "properties": {
            "subnetResourceId": "[resourceId(parameters('WebvNetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', parameters('WebvNetName'), parameters('WebSubnetName-frontend-plan-1'))]",
            "swiftSupported": true
          },
          "dependsOn": [
            "[resourceId('Microsoft.Web/sites', parameters('serviceName'))]"
          ]
        }
      ]
    }
  ]
}
