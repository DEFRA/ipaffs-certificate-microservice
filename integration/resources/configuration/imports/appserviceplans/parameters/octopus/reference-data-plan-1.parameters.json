{
  "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dateCreated": {
      "value": "#{format-DateTag}"
    },
    "envCode": {
      "value": "#{env | ToLower}"
    },
    "ServiceCode":{
      "value":"IMP"
    },
    "Tier":{
      "value":"Web"
    },
    "ServiceType":{
       "value":"LOB"
    },
    "envSuffix": {
      "value": ""
    },
    "serviceCapacity": {
      "value": "#{referenceDataPlan1ServiceCapacity}"
    },
    "servicePlanGroup": {
      "value": "#{appPlanNameReferenceData1}"
    },
    "serviceSKU": {
      "value": "#{referenceDataPlan1ServiceSKU}"
    },
    "serviceCapacityMax": {
      "value": "#{if referenceDataPlan1ServiceCapacityMax}#{referenceDataPlan1ServiceCapacityMax}#{else}#{defaultServiceCapacityMax}#{/if}"
    },
    "autoscaleEnabled": {
      "value": "#{if referenceDataPlan1AutoscaleEnabled}#{referenceDataPlan1AutoscaleEnabled}#{else}#{defaultAutoscaleEnabled}#{/if}"
    },
    "scaleActionIncreaseValue": {
      "value": "#{if referenceDataPlan1ScaleActionIncreaseValue}#{referenceDataPlan1ScaleActionIncreaseValue}#{else}#{defaultScaleActionIncreaseValue}#{/if}"
    },
    "scaleActionIncreaseCooldown": {
      "value": "#{if referenceDataPlan1ScaleActionIncreaseCooldown}#{referenceDataPlan1ScaleActionIncreaseCooldown}#{else}#{defaultScaleActionIncreaseCooldown}#{/if}"
    },
    "metricTriggerIncreaseStatistic": {
      "value": "#{if referenceDataPlan1MetricTriggerIncreaseStatistic}#{referenceDataPlan1MetricTriggerIncreaseStatistic}#{else}#{defaultMetricTriggerIncreaseStatistic}#{/if}"
    },
    "metricTriggerIncreaseTreshold": {
      "value": "#{if referenceDataPlan1MetricTriggerIncreaseTreshold }#{referenceDataPlan1MetricTriggerIncreaseTreshold }#{else}#{defaultMetricTriggerIncreaseTreshold }#{/if}"
    },
    "metricTriggerIncreaseTimeGrain": {
      "value": "#{if referenceDataPlan1MetricTriggerIncreaseTimeGrain}#{referenceDataPlan1MetricTriggerIncreaseTimeGrain}#{else}#{defaultMetricTriggerIncreaseTimeGrain}#{/if}"
    },
    "metricTriggerIncreaseTimeWindow": {
      "value": "#{if referenceDataPlan1MetricTriggerIncreaseTimeWindow}#{referenceDataPlan1MetricTriggerIncreaseTimeWindow}#{else}#{defaultMetricTriggerIncreaseTimeWindow}#{/if}"
    },
    "scaleActionDecreaseValue": {
      "value": "#{if referenceDataPlan1ScaleActionDecreaseValue}#{referenceDataPlan1ScaleActionDecreaseValue}#{else}#{defaultScaleActionDecreaseValue}#{/if}"
    },
    "scaleActionDecreaseCooldown": {
      "value": "#{if referenceDataPlan1ScaleActionDecreaseCooldown}#{referenceDataPlan1ScaleActionDecreaseCooldown}#{else}#{defaultScaleActionDecreaseCooldown}#{/if}"
    },
    "metricTriggerDecreaseStatistic": {
      "value": "#{if referenceDataPlan1MetricTriggerDecreaseStatistic}#{referenceDataPlan1MetricTriggerDecreaseStatistic}#{else}#{defaultMetricTriggerDecreaseStatistic}#{/if}"
    },
    "metricTriggerDecreaseTreshold": {
      "value": "#{if referenceDataPlan1MetricTriggerDecreaseTreshold }#{referenceDataPlan1MetricTriggerDecreaseTreshold }#{else}#{defaultMetricTriggerDecreaseTreshold }#{/if}"
    },
    "metricTriggerDecreaseTimeGrain": {
      "value": "#{if referenceDataPlan1MetricTriggerDecreaseTimeGrain}#{referenceDataPlan1MetricTriggerDecreaseTimeGrain}#{else}#{defaultMetricTriggerDecreaseTimeGrain}#{/if}"
    },
    "metricTriggerDecreaseTimeWindow": {
      "value": "#{if referenceDataPlan1MetricTriggerDecreaseTimeWindow}#{referenceDataPlan1MetricTriggerDecreaseTimeWindow}#{else}#{defaultMetricTriggerDecreaseTimeWindow}#{/if}"
    }
  }
}
