@Library('pipeline-library') _

pipeline {
    agent {label 'master'}
    options {
        ansiColor('xterm')
        timestamps()
        disableConcurrentBuilds()
    }
    parameters {
      string(name: 'RELEASE_CANDIDATE', defaultValue: 'MAJOR.MINOR.PATCH', description: 'Release Candidate to be deployed above sandpit example: 3.4.2')
      booleanParam(name: 'PROMOTE_DOCKER_IMAGES', defaultValue: true, description: 'Would you like to promote docker images to OPS ACR for this release?')
      booleanParam(name: 'PUSH_ARM_TEMPLATES_TO_VSTS', defaultValue: true, description: 'Would you like to push the current ARM Templates within pipeline-library/resources to VSTS for Octopus?')
      string(name: 'ARM_TEMPLATE_BRANCH', defaultValue: 'master', description: 'Would you like to promote templates from a hotfix branch on the *pipeline-library* repository instead of master?')
      booleanParam(name: 'TAG_SELENIUM', defaultValue: true, description: 'Would you like to tag all frontend repositories to match selenium tests to release?')
    }
    environment {
      ENVIRONMENT = "octopus"
    }

    stages {
      stage('Promote Docker Images from SND ACR to OPS ACR') {
        when {
          expression { params.PROMOTE_DOCKER_IMAGES == true }
        }
        steps {
          dockerLogin("Sandpit")
          dockerLogin("${ENVIRONMENT}")
          dockerPromoteToTest("${params.RELEASE_CANDIDATE}", "${ENVIRONMENT}")
        }
      }

      stage('Push ARM Templates to AZURE DEVOPS') {
        when {
          expression { params.PUSH_ARM_TEMPLATES_TO_VSTS == true }
        }
        steps {
          //check out latest pipeline-library master
          git branch: "${ARM_TEMPLATE_BRANCH}", changelog: false, credentialsId: 'testcreds', poll: false, url: 'https://giteux.azure.defra.cloud/imports/pipeline-library.git'
          //copy required code (here ARM templates) to VSTS repo and push to master
          //can be used for other repos as well
          armPromote('pipeline-library', '../../resources/configuration', 'DEFRA-EUX-IMP', 'app', 'defra-eux-imp-vsts', 'defradev.visualstudio.com/DEFRA-Infrastructure/_git', params.RELEASE_CANDIDATE)
        }
      }

      stage('Tag Pipeline Library') {
        steps {
          withCredentials([string(credentialsId: 'JENKINS_GITLAB_TOKEN', variable: 'TOKEN')]) {
            tagBranch("${RELEASE_CANDIDATE}", "${TOKEN}", 'pipeline-library')
          }
        }
      }

      stage('Tag Selenium Code') {
        when {
          expression { params.TAG_SELENIUM == true }
        }
        steps {
          echo "=== Tagging frontend-notification ==="
          build job: 'Tag_A_Repository', parameters: [string(name: 'TAG', value: "${RELEASE_CANDIDATE}"), string(name: 'SERVICE_REPO', value: 'frontend-notification')]
          echo "=== Tagging frontend-control ==="
          build job: 'Tag_A_Repository', parameters: [string(name: 'TAG', value: "${RELEASE_CANDIDATE}"), string(name: 'SERVICE_REPO', value: 'frontend-control')]
          echo "=== Tagging frontend-decision ==="
          build job: 'Tag_A_Repository', parameters: [string(name: 'TAG', value: "${RELEASE_CANDIDATE}"), string(name: 'SERVICE_REPO', value: 'frontend-decision')]
        }
      }

    }

    post {
        always {
          step([$class: 'WsCleanup'])
        }
    }
}
